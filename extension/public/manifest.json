{
  "manifest_version": 3,
  "name": "Arbol",
  "version": "1.0.0",
  "description": "Guardá y organizá tus marcadores en tu archivo personal.",

  "permissions": [
    "bookmarks",
    "activeTab",
    "storage",
    "contextMenus",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "http://localhost:3000/*"
  ],

  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Arbol"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}